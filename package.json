{
  "name": "getfilly",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @getfilly/shared --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:shared": "pnpm --filter @getfilly/shared dev",
    "build": "pnpm --recursive build",
    "supabase:apply-templates": "node scripts/apply-supabase-auth-config.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
