{
  "name": "getfilly",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @getfilly/shared --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:shared": "pnpm --filter @getfilly/shared dev",
    "build": "pnpm --recursive build"
  }
}
