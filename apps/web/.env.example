# Kopieer dit bestand naar .env.local en vul de waardes in.
# .env.local wordt door .gitignore uitgesloten (mag nooit gecommit worden).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Meta (Facebook/Instagram) OAuth — "posten namens de zaak".
# Alleen het App ID hier (voor de authorize-URL van /oauth/meta/start).
# Het App SECRET + de token-exchange + opslag zitten in de Nest-API
# (apps/api/.env: META_APP_SECRET + INTEGRATIONS_ENCRYPTION_KEY) — het
# secret hoort dus NIET in de web-env.
#
# Registreer in Meta (App → Facebook Login → Instellingen → "Geldige
# OAuth-redirect-URI's") exact <origin>/oauth/meta/callback voor elk
# Vercel-domein waarop je de flow draait:
#   nu:    https://www.get-filly.com/oauth/meta/callback
#   later: https://app.get-filly.com/oauth/meta/callback  (Meta-test-URL, zie BACKLOG)
# De redirect_uri wordt van de request-origin afgeleid, dus registreren =
# het enige wat per domein nodig is (geen codewijziging).
META_APP_ID=
# Optioneel: Graph-API-versie overschrijven (default v21.0).
# META_GRAPH_VERSION=v21.0

# Google Bedrijfsprofiel OAuth — "beheren namens de zaak".
# Alleen het Client ID hier (voor de authorize-URL van /oauth/google/start);
# het Client SECRET + token-exchange zitten in de Nest-API (apps/api/.env:
# GOOGLE_OAUTH_CLIENT_SECRET). Registreer in Google Cloud Console exact
# <origin>/oauth/google/callback als geautoriseerde omleidings-URI:
#   prod:   https://www.get-filly.com/oauth/google/callback
#   lokaal: http://localhost:3000/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
# Sleutel waarmee de OAuth-`state` wordt ondertekend (HMAC-SHA256) zodat de
# tenant-id veilig meereist en CSRF wordt geblokkeerd. 32 bytes; genereer
# met:  openssl rand -base64 32
OAUTH_STATE_SECRET=
# Feature-flag: zet op "true" om de live "Verbind"-knop voor Google te tonen.
# Default (leeg/false) → de koppelingen-tab toont alleen "Beheer", geen
# halfdode knop zolang de Google-API-toegang nog niet rond is.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=
