# Kopieer dit bestand naar .env en vul de waardes in.
# .env wordt door .gitignore uitgesloten (mag nooit gecommit worden).

SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Supabase Publishable-key (publieke key, sb_publishable_...) — voor de
# per-request user-scoped Supabase-client. Wordt gepromoveerd tot
# user-niveau via het Authorization-header van de ingelogde user;
# RLS-policies pakken het vanaf daar over. Veilig om te exposen
# (frontend gebruikt 'm ook). Te vinden in Supabase Dashboard →
# Project Settings → API Keys → "Publishable and secret API keys" →
# "Publishable key".
SUPABASE_PUBLISHABLE_KEY=

# Anthropic (Claude) — voor Filly's AI-functies (review-replies,
# suggesties, chat, menu-vision). Maak een key aan op
# https://console.anthropic.com en voeg minimaal ~€10 credit toe.
ANTHROPIC_API_KEY=

# Resend — provider voor outgoing campagne-mails. API-key uit Resend
# dashboard → API Keys met scope "Sending access". Gratis tier: 3k
# mails/maand. Domein get-filly.com staat geverifieerd in Resend EU
# (eu-west-1) sinds 2026-05-04.
RESEND_API_KEY=

# Publieke URL van de web-frontend. Gebruikt voor: unsubscribe-links in
# mails, de data-deletion-statuspagina, én de team-invite-accept-links.
# ⚠️ In productie MOET dit de CANONIEKE host zijn en gelijk aan de
# Supabase Site URL: https://www.get-filly.com (NIET het apex-domein en
# NIET een *.vercel.app-preview — anders weigert /auth/confirm de
# invite-redirect en belandt een uitgenodigd teamlid op /onboarding).
# In dev: http://localhost:3000.
WEB_URL=http://localhost:3000

# Meta (Facebook/Instagram) OAuth — "posten namens de zaak".
# De API doet de token-exchange (code → short-lived → long-lived) en
# slaat de versleutelde token op. App ID + Secret uit
# https://developers.facebook.com → jouw App → Instellingen → Basis.
# (App ID staat OOK in de web-env voor de authorize-URL; het Secret
#  hoort ALLEEN hier.)
META_APP_ID=
META_APP_SECRET=
# Optioneel: Graph-API-versie overschrijven (default v21.0). Houd
# gelijk aan de web-env én het Meta-dashboard.
# META_GRAPH_VERSION=v21.0

# Sleutel waarmee koppeling-tokens app-level worden versleuteld
# (AES-256-GCM) vóór opslag in integration_credentials. 32 bytes.
# Genereer met:  openssl rand -base64 32
# NOOIT roteren zonder bestaande rijen opnieuw te koppelen — oude
# ciphertext wordt anders onleesbaar.
INTEGRATIONS_ENCRYPTION_KEY=

# Cron-secret voor de wekelijkse vindbaarheid-mail (GET /api/seo-report/run).
# Vercel Cron stuurt automatisch `Authorization: Bearer <CRON_SECRET>` mee
# als deze env in het project staat; het endpoint weigert alles zonder de
# juiste waarde. Genereer met:  openssl rand -hex 32
CRON_SECRET=

# Supabase Management API — alleen nodig voor scripts/apply-supabase-auth-config.mjs
# (email-templates synchroniseren naar Supabase). Niet gebruikt door de backend zelf.
# Token aanmaken: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=ttoizamfscichcmzmnsw
