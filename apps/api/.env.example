# Kopieer dit bestand naar .env en vul de waardes in.
# .env wordt door .gitignore uitgesloten (mag nooit gecommit worden).

SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Supabase Publishable-key (publieke key, sb_publishable_...) — voor de
# per-request user-scoped Supabase-client. Wordt gepromoveerd tot
# user-niveau via het Authorization-header van de ingelogde user;
# RLS-policies pakken het vanaf daar over. Veilig om te exposen
# (frontend gebruikt 'm ook). Te vinden in Supabase Dashboard →
# Project Settings → API Keys → "Publishable and secret API keys" →
# "Publishable key".
SUPABASE_PUBLISHABLE_KEY=

# Anthropic (Claude) — voor Filly's AI-functies (review-replies,
# suggesties, chat, menu-vision). Maak een key aan op
# https://console.anthropic.com en voeg minimaal ~€10 credit toe.
ANTHROPIC_API_KEY=

# Resend — provider voor outgoing campagne-mails. API-key uit Resend
# dashboard → API Keys met scope "Sending access". Gratis tier: 3k
# mails/maand. Domein get-filly.com staat geverifieerd in Resend EU
# (eu-west-1) sinds 2026-05-04.
RESEND_API_KEY=

# Publieke URL van de web-frontend — gebruikt voor unsubscribe-links
# in uitgaande mails. In dev: http://localhost:3000. In productie:
# https://get-filly.com (of jouw productie-host).
WEB_URL=http://localhost:3000

# Supabase Management API — alleen nodig voor scripts/apply-supabase-auth-config.mjs
# (email-templates synchroniseren naar Supabase). Niet gebruikt door de backend zelf.
# Token aanmaken: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=ttoizamfscichcmzmnsw
