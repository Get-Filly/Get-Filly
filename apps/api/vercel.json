{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "regions": ["fra1"],
  "installCommand": "pnpm install --frozen-lockfile --filter \"api...\"",
  "buildCommand": "pnpm --filter api build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/seo-report/run", "schedule": "0 5 * * 1" }
  ]
}
